{
  "config": {
    // デフォルトルールを有効化
    "default": true,
    // 行の最大文字数（日本語ドキュメントは長くなりやすいため無効化）
    "MD013": false,
    // インラインHTMLを許可
    "MD033": false,
    // コードブロックの言語指定を不要に
    "MD040": false,
    // テーブルカラムスタイルを不要に
    "MD060": false,
    // ファイル末尾の改行を必須化
    "MD047": true,
    // 同一親見出し下のみ重複チェック（異なるセクション下の同名見出しを許可）
    "MD024": { "siblings_only": true }
  },
  "globs": ["**/*.md"],
  "ignores": [
    "node_modules/**",
    ".claude/**",
    ".agents/**",
    "sample-api/**",
    "sample-front/**",
    // ralph-loop 用のプロンプトファイルは通常の文書ではないため lint 対象から外す
    "plans/**/.ralph-*.md",
    // エントリーポイント・ループ用プロンプトはヘッダー不要な特殊ファイル
    "AGENTS.md",
    "e2e/.ralph-e2e-gen.md"
  ]
}
